#!/bin/bash

# Путь к временной папке, куда pkgbuild распаковал файлы.
# Она передается скрипту как первый аргумент ($1).
INSTALLER_TEMP_DIR="$1"

# 1. Создаем целевую папку для драйвера, если ее нет
mkdir -p "/Library/Audio/Plug-Ins/HAL"

# 2. Копируем драйвер из временной папки в целевую
#    Используем -r для рекурсивного копирования, если это папка
cp -R "$INSTALLER_TEMP_DIR/Library/Audio/Plug-Ins/HAL/"* "/Library/Audio/Plug-Ins/HAL/"

# 3. (Опционально) Устанавливаем правильные права доступа.
#    Владельцем должен быть root, чтобы драйвер мог загружаться.
chown -R root:wheel "/Library/Audio/Plug-Ins/HAL/BlackHole.driver"

# Всегда возвращайте 0, чтобы сообщить установщику об успехе
exit 0
